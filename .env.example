# Firebase Configuration
# Get these values from your Firebase project settings
# https://console.firebase.google.com/

PLASMO_PUBLIC_FIREBASE_PUBLIC_API_KEY=your-api-key-here
PLASMO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
PLASMO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PLASMO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
PLASMO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
PLASMO_PUBLIC_FIREBASE_APP_ID=your-app-id-here
PLASMO_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id-here

# Backend Server URL
# For development: http://localhost:5000
# For production: https://your-backend-url.com
PLASMO_PUBLIC_BACKEND_URL=http://localhost:5000
